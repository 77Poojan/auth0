<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Signed Out — MyApp</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>

<div class="logout-page">

  <div class="logout-card">
    <div class="logout-icon" aria-hidden="true">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
        <polyline points="16 17 21 12 16 7"/>
        <line x1="21" y1="12" x2="9" y2="12"/>
      </svg>
    </div>

    <h1>You've been signed out</h1>
    <p class="logout-sub">Your session has ended and your account is secure.</p>

    <hr class="logout-divider" />

    <div class="logout-actions">
      <a href="/login" class="btn btn--primary">Sign back in</a>
      <a href="/" class="btn btn--outline">Go to home</a>
    </div>

    <p class="logout-reassurance">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      Tokens and session data have been cleared.
    </p>

    <p class="logout-redirect" id="redirectMsg">Redirecting to home in <strong id="countdown">10</strong>s…</p>
  </div>

  <footer class="logout-footer">
    <div class="brand-logo" aria-hidden="true">
      <svg width="13" height="13" viewBox="0 0 22 22" fill="none">
        <path d="M11 2L19 6.5V15.5L11 20L3 15.5V6.5L11 2Z" stroke="white" stroke-width="1.8" stroke-linejoin="round"/>
        <circle cx="11" cy="11" r="3" fill="white"/>
      </svg>
    </div>
    <span>MyApp &middot; Secured by Auth0</span>
  </footer>

</div>

<script>
  (function () {
    try { sessionStorage.clear(); } catch (_) {}

    let t = 10;
    const countEl = document.getElementById('countdown');
    const msgEl   = document.getElementById('redirectMsg');
    const timer   = setInterval(() => {
      t -= 1;
      if (t <= 0) { clearInterval(timer); window.location.href = '/'; return; }
      countEl.textContent = t;
    }, 1000);

    document.querySelectorAll('.btn').forEach(btn => {
      btn.addEventListener('click', () => { clearInterval(timer); msgEl.remove(); });
    });
  })();
</script>

</body>
</html>
