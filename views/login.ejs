<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign In — MyApp</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>

<div class="auth-page">

  <aside class="sidebar">
    <div class="sidebar__top">
      <div class="brand">
        <div class="brand-logo">
          <svg width="20" height="20" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M11 2L19 6.5V15.5L11 20L3 15.5V6.5L11 2Z" stroke="white" stroke-width="1.6" stroke-linejoin="round"/>
            <circle cx="11" cy="11" r="3" fill="white"/>
          </svg>
        </div>
        <div>
          <p class="brand-name">MyApp</p>
          <p class="brand-sub">Powered by Auth0</p>
        </div>
      </div>

      <ul class="feature-list">
        <li><span class="feature-check">&#10003;</span> Single sign-on</li>
        <li><span class="feature-check">&#10003;</span> Multi-factor auth</li>
        <li><span class="feature-check">&#10003;</span> Secure token rotation</li>
      </ul>
    </div>
    <p class="sidebar__tagline">Enterprise-grade identity, zero configuration.</p>
  </aside>

  <main class="auth-main">
    <div class="form-wrap">

      <div class="form-header">
        <h1>Welcome back</h1>
        <p>Sign in to continue to your account</p>
      </div>

      <% if (error === 'access_denied') { %>
        <div class="alert alert--warning" role="alert">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Login was cancelled. Please try again.
        </div>
      <% } %>

      <% if (error && error !== 'access_denied') { %>
        <div class="alert alert--error" role="alert">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <%= error_description || 'Authentication failed. Please try again.' %>
        </div>
      <% } %>

      <form id="loginForm" novalidate>
        <div class="field">
          <label for="email">Email address</label>
          <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input type="email" id="email" name="email" placeholder="you@example.com" autocomplete="email" required />
          </div>
          <span class="field-error" id="emailError" role="alert"></span>
        </div>

        <div class="field">
          <div class="field-label-row">
            <label for="password">Password</label>
            <a href="/forgot-password" class="forgot-link">Forgot password?</a>
          </div>
          <div class="input-wrap">
            <svg class="input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <input type="password" id="password" name="password" placeholder="••••••••" autocomplete="current-password" required />
            <button type="button" class="pw-toggle" id="pwToggle" aria-label="Show password">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <span class="field-error" id="passwordError" role="alert"></span>
        </div>

        <button type="submit" class="btn btn--primary" id="submitBtn">
          <span class="btn-label">Sign in</span>
          <span class="btn-spinner" id="btnSpinner" hidden aria-hidden="true"></span>
        </button>
      </form>

      <div class="divider"><span>or continue with</span></div>

      <a href="/login?connection=google-oauth2" class="btn btn--social">
        <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
        </svg>
        Continue with Google
      </a>

      <p class="signup-row">Don't have an account? <a href="/signup">Create one</a></p>

    </div>
  </main>

</div>

<script src="/js/login.js"></script>
</body>
</html>
